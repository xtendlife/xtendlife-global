    "image_with_text_HHyM8a": {
      "type": "image-with-text",
      "blocks": {
        "heading_zhEGVe": {
          "type": "heading",
          "settings": {
            "heading": "Multivitamin for your heart",
            "heading_size": "h1"
          }
        },
        "caption_rgGCKg": {
          "type": "caption",
          "settings": {
            "caption": "It’s never too late to improve your cardiovascular health, heart disease is largely preventable through lifestyle change and great supplementation. Xtendlife CX8 is developed with the best ingredients supported by science to keep you stay young at heart.",
            "additional_caption": "",
            "text_style": "subtitle",
            "text_size": "small"
          }
        },
        "collapsible_row_AeCpAw": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Highly Advanced Natural Supplement",
            "row_content": "<p>CX8 is formulated with highly researched ingredients backed by data to support calcium metabolism, circulation, and inflammation management. The eight potent ingredients formula offers you one of the most effective heart-health products available today.</p>",
            "page": "",
            "open": true
          }
        },
        "collapsible_row_AjWcwC": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Circulation and Calcification",
            "row_content": "<p>CX8 contains a proprietary blend of protease enzymes (Nattozimes®) and vitamin K2 in MK-7 form, these well-researched ingredients present great evidence to support calcium metabolism and may prevent the buildup of calcium in the arteries.</p>",
            "page": "",
            "open": false
          }
        },
        "collapsible_row_ciD4cW": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Inflammation and Cellular Support",
            "row_content": "<p>It contains DeltaGold® tocotrienol complex, the most potent anti-inflammatory vitamin E, to help prevent lipid oxidation in CVD, and support cardiovascular and metabolic health.</p>",
            "page": "",
            "open": false
          }
        },
        "collapsible_row_HfKygV": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Additional Antioxidants",
            "row_content": "<p>This unique heart health supplement also contains additional antioxidants sea buckthorn fruit extract (CardiOmegia™, CyanthOx™30), rutin and New Zealand blackcurrant extract, great for supporting healthy inflammation and heart health.</p>",
            "page": "",
            "open": false
          }
        },
        "button_CdnLhT": {
          "type": "button",
          "settings": {
            "button_label": "Shop CX8",
            "button_link": "shopify://products/cx8-heart-health-support",
            "button_style_secondary": false
          }
        }
      },
