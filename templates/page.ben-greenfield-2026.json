    "image_with_text_83HE6c": {
      "type": "image-with-text",
      "blocks": {
        "heading_6bVe4M": {
          "type": "heading",
          "settings": {
            "heading": "Healthy Aging with GG Pure",
            "heading_size": "h1"
          }
        },
        "caption_MdCprz": {
          "type": "caption",
          "settings": {
            "caption": "Geranylgeraniol (GG) is the building block for essential-to-life nutrient. However, most people may haven't heard of it, Scientists discovered that this molecule plays a vital role in overall health. A decline in GG levels is linked to many of the common side effects experienced by those taking statins.",
            "additional_caption": "",
            "text_style": "subtitle",
            "text_size": "small"
          }
        },
        "collapsible_row_4b8wHk": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Innovative formula backed by science",
            "row_content": "<p>GG Pure is formulated with the trademarked ingredient GG Gold®, which has been featured in numerous independent studies over the decades for its efficacy and safety.</p>",
            "page": "",
            "open": true
          }
        },
        "collapsible_row_XxRk8y": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Support CoQ10 and Cholesterol Synthesis",
            "row_content": "<p>Geranylgeraniol (GG) is the building block of CoQ10, restoring a healthy level of GG may support your body’s natural production of CoQ10 for better heart health and cholesterol metabolism, and protect organs from age-related physical decline.</p>",
            "page": "",
            "open": false
          }
        },
        "collapsible_row_VjbeiX": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Support Muscle Comfort",
            "row_content": "<p>Muscle pain & deterioration are side effects of statins, which are largely due to the body not being able to carry out the protein prenylation; GG influences skeletal muscle protein synthesis, which may may assist in mitigating these side effects.</p>",
            "page": "",
            "open": false
          }
        },
        "collapsible_row_LKKWzb": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Unique Annatto Seed from the Amazon Forest",
            "row_content": "<p>GG Pure is formulated with a unique annatto seed extract, one of the most abundant sources of GG in nature. This special extract has been extensively studied for its safety and efficacy, to support the replenishment of GG lost.</p>",
            "page": "",
            "open": false
          }
        },
        "button_7xtrmP": {
          "type": "button",
          "settings": {
            "button_label": "Shop GG Pure",
            "button_link": "shopify://products/gg-pure",
            "button_style_secondary": false
          }
        }
      },
